{
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5",
    "API_TIMEOUT_MS": "3000000"
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "mcp__context7__*",
      "mcp__web_reader__*",
      "Bash(claude*)",
      "Bash(pytest*)",
      "Bash(python3 -m pytest*)",
      "Bash(coverage*)",
      "Bash(python3 -m coverage*)",
      "Bash(mutmut-wrapper*)",
      "Bash(coverage-wrapper*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(sudo:*)",
      "Bash(rm -rf /)*",
      "Bash(rm -rf $HOME)*",
      "Bash(umask *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(chgrp *)",
      "Bash(setfacl *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(systemctl *)",
      "Bash(dd *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/*)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/.netrc)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(**/id_dsa)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(./.env)",
      "Write(./.env.*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-secrets.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/allow-readonly.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-git.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-dangerous.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-workarounds.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-secrets.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-workarounds.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/format-on-save.py",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "sandbox": {
    "mode": "auto-allow",
    "allowedDomains": [
      "registry.npmjs.org",
      "pypi.org",
      "api.github.com",
      "raw.githubusercontent.com"
    ]
  },
  "skills": {
    "global": []
  },
  "effortLevel": "high"
}
